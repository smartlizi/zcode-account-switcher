{
  "name": "zcode-account-switcher-desktop",
  "version": "1.0.0",
  "description": "ZCode 账号无感切换器 - 桌面版",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smartlizi/zcode-account-switcher.git"
  },
  "build": {
    "appId": "com.zcode.account-switcher",
    "productName": "ZCode Account Switcher",
    "copyright": "MIT",
    "publish": {
      "provider": "github",
      "owner": "smartlizi",
      "repo": "zcode-account-switcher"
    },
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "protocols": [
      {
        "name": "ZCode Auth Callback",
        "schemes": ["zcode"]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "dist-renderer/**",
      "assets/**",
      "node_modules/**",
      "!node_modules/zcode-account-switcher/**",
      "!node_modules/.bin/**",
      "!node_modules/electron/**",
      "!node_modules/vite/**",
      "!node_modules/@vitejs/**",
      "!node_modules/concurrently/**",
      "!node_modules/cross-env/**",
      "!node_modules/wait-on/**",
      "!node_modules/electron-builder/**"
    ],
    "extraResources": [
      {
        "from": "../src",
        "to": "app-src",
        "filter": [
          "**/*.js"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZCode Account Switcher"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "title": "ZCode Account Switcher"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  },
  "dependencies": {
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zcode-account-switcher": "file:.."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
